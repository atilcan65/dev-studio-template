[Unit]
Description=Watch agent-watch.sh for changes and reload all watchers
Documentation=https://github.com/atilcan65/atilprojects/blob/main/docs/decisions/ADR-0006-watcher-resilience.md

[Path]
# Fires on IN_CLOSE_WRITE + IN_MOVED_TO (atomic replace via git pull, editor save)
PathChanged=/opt/dev-studio/atilprojects/scripts/agent-watch.sh
# Trigger the reload service; the service handles the actual restart fan-out
Unit=dev-studio-watcher-reload.service

[Install]
WantedBy=default.target
